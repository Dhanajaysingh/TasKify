<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Read More</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10">
    <h1 class="text-white mb-4"><strong><%= filename %></strong> </h1>
    <pre class="text-green-400 mb-2"><%= content %></pre>
    <input class="mt-2 bg-blue-600 px-4  text-white rounded-md" type="submit" value="Back" onclick="window.history.back()">
    <input class="mt-2 bg-red-600 px-4 text-white rounded-md" type="submit" value="Delete Task" onclick="window.location.href='/delete/<%= filename %>'">
    </div> 
</body>
</html>
